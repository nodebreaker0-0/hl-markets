{
  "name": "@hl-markets/api",
  "version": "0.0.1",
  "private": true,
  "description": "hl-markets backend — Hono single Node process (HTTP + node-cron indexer).",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.4",
    "ulid": "^2.3.0",
    "viem": "^2.21.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.0",
    "tsx": "^4.19.2",
    "typescript": "~5.5.4",
    "vitest": "^2.0.0"
  }
}
