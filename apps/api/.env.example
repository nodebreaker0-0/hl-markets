NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://hl_gov:dev@localhost:5432/hl_gov
ALLOWED_ORIGINS=http://localhost:3000
INDEXER_INTERVAL_CRON=*/1 * * * *
INDEXER_ENABLED=true

# Phase J.1 session JWT — generate with: openssl rand -hex 32
SESSION_JWT_SECRET=dev-only-not-for-prod-please-rotate-me
# Set true in prod so the session cookie gets the Secure flag (HTTPS only)
COOKIE_SECURE=false

# Phase J.5 Builder Code — per network. Set to your personal EOA after running
# approveBuilderFee from the builder side. Defaults are zero (= disabled).
# Fee unit is tenths-of-bps; 50 = 5 bps = 0.05%. HL caps at 100 (perp) / 1000 (spot).
BUILDER_ADDR_TESTNET=0x0000000000000000000000000000000000000000
BUILDER_ADDR_MAINNET=0x0000000000000000000000000000000000000000
BUILDER_MAX_FEE_TENTHS_BPS=50
