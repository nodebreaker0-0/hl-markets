NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://hl_gov:dev@localhost:5432/hl_gov
ALLOWED_ORIGINS=http://localhost:3000
INDEXER_INTERVAL_CRON=*/1 * * * *
INDEXER_ENABLED=true

# Phase J.1 session JWT — generate with: openssl rand -hex 32
SESSION_JWT_SECRET=dev-only-not-for-prod-please-rotate-me
# Set true in prod so the session cookie gets the Secure flag (HTTPS only)
COOKIE_SECURE=false
