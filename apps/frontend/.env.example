# Network this build targets. hl-markets is deployed twice in parallel —
# pick one. Anything other than "mainnet" is treated as testnet.
NEXT_PUBLIC_HL_NETWORK=testnet

# Backend (hl-markets-api) base URL — used for historical outcome governance.
# Set per-environment. The frontend is a static SPA so this URL is baked in
# at build time.
#
# NEXT_PUBLIC_API_BASE=http://localhost:3001
