# Network this build targets. hl-markets is deployed twice in parallel —
# pick one. Anything other than "mainnet" is treated as testnet.
NEXT_PUBLIC_HL_NETWORK=testnet

# Backend (hl-markets-api) base URL — used for historical outcome governance.
# Set per-environment. The frontend is a static SPA so this URL is baked in
# at build time.
#
# NEXT_PUBLIC_API_BASE=http://localhost:3001

# Phase J.5 Builder Code (set per-network EOAs after approveBuilderFee ran)
# NEXT_PUBLIC_BUILDER_ADDR_TESTNET=0x...
# NEXT_PUBLIC_BUILDER_ADDR_MAINNET=0x...
# Order fee in human bps (5 = 0.05%). The approveBuilderFee maxFeeRate is
# auto-derived from this value so the user-approved cap never undercuts the
# order fee (which would silently fail on HF with "Builder fee has not been
# approved.").
NEXT_PUBLIC_BUILDER_FEE_BPS=5
